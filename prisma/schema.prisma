// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model CampingPlace {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  location    String
  size        Int
  price       Float
  amenities   String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  bookings    Booking[]
  
  @@map("camping_places")
}

model Booking {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  campingPlaceId String   @db.ObjectId
  customerName   String
  customerEmail  String
  customerPhone  String?
  startDate     DateTime
  endDate       DateTime
  guests        Int
  totalPrice    Float
  status        BookingStatus @default(PENDING)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  campingPlace  CampingPlace @relation(fields: [campingPlaceId], references: [id])
  
  @@map("bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
