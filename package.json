{
  "name": "camping-place-manager",
  "version": "1.0.0",
  "type": "module",
  "description": "Tool to handle camping-areas with time-slots and a simple database written in next.js/react",
  "private": true,
  "scripts": {
    "setup": "npm install && npm run db:generate",
    "clean": "rm -rf .next out .vercel *.tsbuildinfo",
    "clean:all": "npm run clean && rm -rf node_modules",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:start": "node scripts/db-start.mjs",
    "db:stop": "node scripts/db-stop.mjs",
    "db:restart": "node scripts/db-restart.mjs",
    "db:status": "node scripts/db-status.mjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e:install": "playwright install",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test && npm run test:e2e"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@prisma/client": "^6.1.0",
    "mongodb": "^6.20.0",
    "next": "^15.5.4",
    "prisma": "^6.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "server-only": "^0.0.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.5.4",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.6",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mthoericht/camping-place-manager.git"
  },
  "keywords": [
    "camping",
    "manager",
    "nextjs",
    "react",
    "typescript",
    "mongodb",
    "prisma"
  ],
  "author": "Marcus Thöricht",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/mthoericht/camping-place-manager/issues"
  },
  "homepage": "https://github.com/mthoericht/camping-place-manager#readme"
}
