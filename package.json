{
  "name": "camping-place-manager",
  "version": "1.0.0",
  "type": "module",
  "description": "Tool to handle camping-areas with time-slots and a simple database written in next.js/react",
  "private": true,
  "scripts": {
    "setup": "npm install && npm run db:generate",
    "clean": "rm -rf .next out .vercel *.tsbuildinfo",
    "clean:all": "npm run clean && rm -rf node_modules",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "./studio.sh",
    "db:start": "./start-db.sh",
    "db:stop": "./stop-db.sh",
    "db:restart": "./restart-db.sh",
    "db:status": "./logs.sh"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "mongodb": "^6.20.0",
    "next": "^15.5.4",
    "prisma": "^6.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.5.4",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mthoericht/camping-place-manager.git"
  },
  "keywords": [
    "camping",
    "manager",
    "nextjs",
    "react",
    "typescript",
    "mongodb",
    "prisma"
  ],
  "author": "Marcus Thöricht",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/mthoericht/camping-place-manager/issues"
  },
  "homepage": "https://github.com/mthoericht/camping-place-manager#readme"
}
